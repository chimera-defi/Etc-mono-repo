{
  "permissions": {
    "allow": [
      "Bash(./skills/token-reduce/scripts/token-reduce-search.sh *)",
      "Bash(bash ./skills/token-reduce/scripts/token-reduce-search.sh *)",
      "Bash(./skills/token-reduce/scripts/token-reduce-paths.sh *)",
      "Bash(bash ./skills/token-reduce/scripts/token-reduce-paths.sh *)",
      "Bash(./skills/token-reduce/scripts/token-reduce-snippet.sh *)",
      "Bash(bash ./skills/token-reduce/scripts/token-reduce-snippet.sh *)",
      "Bash(qmd search *)"
    ]
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/skills/token-reduce/scripts/remind-token-reduce.py"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/skills/token-reduce/scripts/advise-token-reduction.py"
          }
        ]
      },
      {
        "matcher": "Glob",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/skills/token-reduce/scripts/enforce-glob-scope.py"
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/enforce-targeted-read.py"
          }
        ]
      },
      {
        "matcher": "Grep",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/enforce-grep-limits.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Glob",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/warn-glob-explosion.py"
          }
        ]
      }
    ]
  }
}
