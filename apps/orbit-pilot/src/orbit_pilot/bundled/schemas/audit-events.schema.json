{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://orbit-pilot.local/schemas/audit-events.schema.json",
  "title": "OrbitPilotAuditEvents",
  "description": "Machine output of: orbit audit --run … --json (array of JSONL events)",
  "type": "array",
  "items": {
    "type": "object",
