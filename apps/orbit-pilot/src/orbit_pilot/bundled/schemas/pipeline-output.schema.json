    "ok_check_run": { "type": "boolean" },
    "plan": { "type": "object", "additionalProperties": true },
    "doctor": { "type": "object", "additionalProperties": true },
    "generate": { "type": "object", "additionalProperties": true },
    "check_run": { "type": "object", "additionalProperties": true }
