{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://orbit-pilot.local/schemas/schedule-job.schema.json",
  "title": "OrbitPilotScheduleJob",
  "description": "One line object in schedule JSONL or orbit schedule-add --json output",
  "type": "object",
  "required": ["id", "due_at", "cwd", "argv", "created_at", "done"],
  "properties": {
    "id": { "type": "string" },
    "due_at": { "type": "string" },
    "cwd": { "type": "string" },
    "argv": { "type": "array", "items": { "type": "string" } },
    "created_at": { "type": "string" },
    "done": { "type": "boolean" },
    "cancelled": { "type": "boolean" },
    "cancelled_at": { "type": "string" },
    "last_run_at": { "type": "string" },
    "last_exit_code": { "type": "integer" },
    "last_stderr_tail": { "type": "string" }
  },
  "additionalProperties": true
}
