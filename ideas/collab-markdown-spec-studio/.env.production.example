NEXT_PUBLIC_SKIP_AUTH_OVERRIDE=false
SPECFORGE_PERSISTENCE_BACKEND=postgres
DATABASE_URL=postgres://specforge:replace_me@postgres:5432/specforge
SPECFORGE_POSTGRES_SSL=true
SPECFORGE_REQUIRE_SECURE_SECRETS=true
SPECFORGE_SECURE_COOKIES=true
SPECFORGE_SESSION_SECRET=replace_me
SPECFORGE_COLLAB_SECRET=replace_me
SPECFORGE_GITHUB_REDIRECT_URI=https://your-specforge-host/api/auth/callback
SPECFORGE_COLLAB_STORE_DIR=/var/lib/specforge/collab-rooms
SPECFORGE_FIXTURES_DIR=/fixtures
NEXT_PUBLIC_COLLAB_URL=wss://your-collab-host
PORT=3000
HEALTH_PORT=4322
