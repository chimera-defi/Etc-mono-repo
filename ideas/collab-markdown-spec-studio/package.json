{
  "name": "specforge-workspace",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "SpecForge collaborative markdown spec studio - pnpm workspace root",
  "scripts": {
    "dev:up": "pnpm --parallel --filter specforge-web --filter specforge-collab-server dev",
    "dev:web": "pnpm --filter specforge-web dev",
    "dev:collab": "pnpm --filter specforge-collab-server dev",
    "specforge": "pnpm --filter @specforge/cli specforge",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down",
    "build": "pnpm --filter specforge-web build",
    "test:cli": "pnpm --filter @specforge/cli test",
    "lint": "pnpm --filter specforge-web lint",
    "test": "pnpm --filter specforge-web test",
    "test:acceptance": "pnpm --filter specforge-web test:acceptance",
    "test:e2e": "pnpm --filter specforge-web test:e2e",
    "state:reset": "rm -rf web/.data",
    "state:backup": "node ./tools/backup-local-state.mjs",
    "contracts:validate": "jq empty contracts/v1/*.json contracts/v1/examples/*.json",
    "parity:status": "pnpm --filter specforge-web parity:status",
    "parity:context": "pnpm --filter specforge-web parity:context",
    "parity:brief": "pnpm --filter specforge-web parity:brief",
    "parity:run:dry": "pnpm --filter specforge-web parity:run:dry",
    "parity:run": "pnpm --filter specforge-web parity:run",
    "parity:run:batch": "pnpm --filter specforge-web parity:run:batch"
  }
}
