{
  "name": "specforge-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:acceptance": "vitest run tests/acceptance/",
    "test:e2e": "playwright test",
    "screenshot:demo": "playwright test tests/demo.spec.ts --project=chromium",
    "parity:status": "node ../tools/specforge-parity-runner.mjs status",
    "parity:context": "node ../tools/specforge-parity-runner.mjs context",
    "parity:brief": "node ../tools/specforge-parity-runner.mjs brief",
    "parity:run": "node ../tools/specforge-parity-runner.mjs run",
    "parity:run:batch": "node ../tools/specforge-parity-runner.mjs run --until-clear --max-passes 3 --review-every 2",
    "parity:run:dry": "node ../tools/specforge-parity-runner.mjs run --dry-run --max-passes 1"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.3.16",
    "@hocuspocus/provider": "^3.4.4",
    "@tiptap/extension-collaboration": "^3.20.1",
    "@tiptap/react": "^3.20.1",
    "@tiptap/starter-kit": "^3.20.1",
    "@types/pg": "^8.18.0",
    "next": "^16.2.0",
    "pg": "^8.20.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "yjs": "^13.6.29",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^16.2.0",
    "typescript": "^5",
    "vitest": "^4.1.0"
  }
}
