# SpecForge Environment Configuration

# Create a GitHub OAuth App at https://github.com/settings/applications/new
# Set the Authorization callback URL to http://localhost:3000/api/auth/callback
# These values are optional — when omitted the local actor selector is used instead.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
SPECFORGE_GITHUB_REDIRECT_URI=http://localhost:3000/api/auth/callback

# Session signing secret (defaults to dev-only value if unset)
SPECFORGE_SESSION_SECRET=

# Collaboration token secret (defaults to dev-only value if unset)
SPECFORGE_COLLAB_SECRET=

# Local dev auth override: set to "true" to skip GitHub auth
# and use the local actor selector instead.
NEXT_PUBLIC_SKIP_AUTH_OVERRIDE=true

# Database path (defaults to .data/specforge-store.json)
# Use "memory://test" for in-memory testing
SPECFORGE_DB_PATH=

# Hosted persistence backend (optional). Set to "postgres" for hosted mode.
SPECFORGE_PERSISTENCE_BACKEND=
DATABASE_URL=
SPECFORGE_POSTGRES_SSL=

# Fixtures directory (defaults to ../fixtures)
SPECFORGE_FIXTURES_DIR=
