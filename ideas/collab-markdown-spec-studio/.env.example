# Database
DATABASE_URL=postgresql://localhost:5432/specforge_dev

# Next.js
NEXT_PUBLIC_SKIP_AUTH_OVERRIDE=true

# GitHub OAuth (for pilot/production auth)
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_CALLBACK_URL=http://localhost:3000/api/auth/callback/github

# Session
NEXTAUTH_SECRET=your_nextauth_secret
NEXTAUTH_URL=http://localhost:3000

# AI/Agent Config
ANTHROPIC_API_KEY=your_anthropic_key

# Collaboration Server
HOCUSPOCUS_HOST=localhost
HOCUSPOCUS_PORT=1234
