{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "specforge/v1/patch_proposal.request.schema.json",
  "title": "PatchProposalRequest",
  "type": "object",
  "required": ["document_id", "section_id", "operation", "proposed_by", "base_version"],
  "properties": {
    "document_id": { "type": "string", "minLength": 1 },
    "section_id": { "type": "string", "minLength": 1 },
    "operation": { "type": "string", "enum": ["insert", "replace", "delete"] },
    "content": { "type": "string" },
    "rationale": { "type": "string", "maxLength": 1000 },
    "proposed_by": {
      "type": "object",
      "required": ["actor_type", "actor_id"],
      "properties": {
        "actor_type": { "type": "string", "enum": ["human", "agent"] },
        "actor_id": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "base_version": { "type": "integer", "minimum": 1 },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
  },
  "additionalProperties": false
}
